---
// ISO 27001:2022 coverage overview — reads data from crosswalk JSON
import isoCoverageData from '../data/iso27001-coverage.json';

const sections = isoCoverageData.sections;
const clauseNames: Record<string, string> = isoCoverageData._clause_names;
const annexANames: Record<string, string> = isoCoverageData._annexA_names;

const TOTAL_CLAUSES = 26;
const TOTAL_ANNEX_A = 93;

interface TieredIds {
  covered: string[];
  referenced: string[];
}
interface SectionCov {
  clauses: TieredIds;
  annexA: TieredIds;
}

const sectionMeta: Record<string, { label: string }> = {
  gobernantza: { label: '1. Gobernantza' },
  identifikatu: { label: '2. Identifikatu' },
  babestu: { label: '3. Babestu' },
  detektatu: { label: '4. Detektatu' },
  erantzun: { label: '5. Erantzun' },
  berreskuratu: { label: '6. Berreskuratu' },
};

interface SectionRow {
  slug: string;
  label: string;
  covClauses: string[];
  refClauses: string[];
  covAnnexA: string[];
  refAnnexA: string[];
  covClausesPct: number;
  covAnnexAPct: number;
  totalClausesPct: number;
  totalAnnexAPct: number;
}

const rows: SectionRow[] = Object.entries(sections).map(([slug, cov]) => {
  const s = cov as SectionCov;
  const covC = [...new Set(s.clauses.covered)].sort();
  const refC = [...new Set(s.clauses.referenced)].sort();
  const covA = [...new Set(s.annexA.covered)].sort();
  const refA = [...new Set(s.annexA.referenced)].sort();
  // deduplicate: referenced IDs that also appear as covered only count once in total
  const totalC = new Set([...covC, ...refC]);
  const totalA = new Set([...covA, ...refA]);
  return {
    slug,
    label: sectionMeta[slug]?.label ?? slug,
    covClauses: covC,
    refClauses: refC,
    covAnnexA: covA,
    refAnnexA: refA,
    covClausesPct: Math.round((covC.length / TOTAL_CLAUSES) * 100),
    covAnnexAPct: Math.round((covA.length / TOTAL_ANNEX_A) * 100),
    totalClausesPct: Math.round((totalC.size / TOTAL_CLAUSES) * 100),
    totalAnnexAPct: Math.round((totalA.size / TOTAL_ANNEX_A) * 100),
  };
});

// Global covered counts
const allCovClauses = new Set<string>();
const allCovAnnexA = new Set<string>();
const allRefClauses = new Set<string>();
const allRefAnnexA = new Set<string>();
for (const r of rows) {
  for (const id of r.covClauses) allCovClauses.add(id);
  for (const id of r.covAnnexA) allCovAnnexA.add(id);
  for (const id of r.refClauses) allRefClauses.add(id);
  for (const id of r.refAnnexA) allRefAnnexA.add(id);
}

const globalCovClausesPct = Math.round((allCovClauses.size / TOTAL_CLAUSES) * 100);
const globalCovAnnexAPct = Math.round((allCovAnnexA.size / TOTAL_ANNEX_A) * 100);
const globalTotalClauses = new Set([...allCovClauses, ...allRefClauses]).size;
const globalTotalAnnexA = new Set([...allCovAnnexA, ...allRefAnnexA]).size;
const globalTotalClausesPct = Math.round((globalTotalClauses / TOTAL_CLAUSES) * 100);
const globalTotalAnnexAPct = Math.round((globalTotalAnnexA / TOTAL_ANNEX_A) * 100);
---

<style is:global>
  /* ══════════════════════════════════════════ */
  /*  ISO 27001 coverage — scoped via data attr */
  /*  Uses data-zik-coverage to win specificity over Starlight layers */
  /* ══════════════════════════════════════════ */

  /* Summary cards */
  [data-zik-coverage] .zik-card {
    background: var(--zik-surface);
    border: 1px solid var(--zik-border-light);
    border-radius: var(--zik-radius-lg);
    padding: 1.25rem;
    text-align: center;
  }
  [data-zik-coverage] .zik-card-num {
    font-family: var(--zik-font-display);
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--zik-ink);
  }
  [data-zik-coverage] .zik-card-label {
    color: var(--zik-ink-muted);
    font-size: 0.8125rem;
    margin-top: 0.25rem;
  }
  [data-zik-coverage] .zik-card-bar {
    margin-top: 0.75rem;
    width: 100%;
    height: 6px;
    background: var(--zik-border-light);
    border-radius: 3px;
    overflow: hidden;
  }
  [data-zik-coverage] .zik-card-fill {
    height: 100%;
    background: var(--zik-ink);
    border-radius: 3px;
  }
  [data-zik-coverage] .zik-card-pct {
    font-size: 0.75rem;
    color: var(--zik-ink-muted);
    margin-top: 0.25rem;
  }
  [data-zik-coverage] .zik-card-sub {
    font-size: 0.6875rem;
    color: var(--zik-ink-muted);
    margin-top: 0.35rem;
  }

  /* Summary table */
  [data-zik-coverage] .zik-summary-table {
    overflow-x: auto;
  }
  [data-zik-coverage] .zik-summary-table .muted {
    color: var(--zik-ink-muted);
  }
  [data-zik-coverage] .zik-summary-table .mono {
    font-family: var(--zik-font-mono);
  }

  /* Legend */
  [data-zik-coverage] .zik-legend {
    font-size: 0.8125rem;
    color: var(--zik-ink-muted);
    margin-bottom: 1.5rem;
  }

  /* Tags */
  [data-zik-coverage] .zik-tag {
    display: inline-block;
    padding: 0.05rem 0.375rem;
    border-radius: 3px;
    font-size: 0.6875rem;
    margin-left: 0.375rem;
    vertical-align: middle;
  }
  [data-zik-coverage] .zik-tag--covered {
    background: var(--zik-ink);
    color: #fff;
  }
  [data-zik-coverage] .zik-tag--referenced {
    background: var(--zik-border);
    color: var(--zik-ink-muted);
  }

  /* Section details blocks */
  [data-zik-coverage] .zik-section {
    margin-top: 2.5rem;
  }
  [data-zik-coverage] .zik-section h4 {
    margin-bottom: 0.75rem;
  }

  /* Details (collapsible) */
  [data-zik-coverage] details.zik-details {
    margin-bottom: 1rem;
  }
  [data-zik-coverage] .zik-details > summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--zik-ink);
  }
  [data-zik-coverage] .zik-details table {
    margin-top: 0.5rem;
  }
  [data-zik-coverage] .zik-details th {
    color: var(--zik-ink-muted);
  }

  /* Tiered table rows */
  [data-zik-coverage] tr.zik-row--covered td {
    color: var(--zik-ink);
  }
  [data-zik-coverage] tr.zik-row--referenced td {
    color: var(--zik-ink-muted);
  }
  [data-zik-coverage] .zik-details td.zik-id {
    font-family: var(--zik-font-mono);
    font-size: 0.8125rem;
    white-space: nowrap;
  }

  /* Footer note */
  [data-zik-coverage] .zik-footnote {
    font-size: 0.8125rem;
    color: var(--zik-ink-muted);
    margin-top: 2.5rem;
  }
</style>

<div data-zik-coverage>

  <!-- Summary cards -->
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin:1.5rem 0 2.5rem 0;">
    <div class="zik-card">
      <div class="zik-card-num">{allCovClauses.size}/{TOTAL_CLAUSES}</div>
      <div class="zik-card-label">ISMS klausulak (4–10) — sakonduak</div>
      <div class="zik-card-bar">
        <div class="zik-card-fill" style={`width:${globalCovClausesPct}%`}></div>
      </div>
      <div class="zik-card-pct">{globalCovClausesPct}%</div>
      <div class="zik-card-sub">+{allRefClauses.size} aipatuak → {globalTotalClausesPct}%</div>
    </div>
    <div class="zik-card">
      <div class="zik-card-num">{allCovAnnexA.size}/{TOTAL_ANNEX_A}</div>
      <div class="zik-card-label">Annex A kontrolak — sakonduak</div>
      <div class="zik-card-bar">
        <div class="zik-card-fill" style={`width:${globalCovAnnexAPct}%`}></div>
      </div>
      <div class="zik-card-pct">{globalCovAnnexAPct}%</div>
      <div class="zik-card-sub">+{allRefAnnexA.size} aipatuak → {globalTotalAnnexAPct}%</div>
    </div>
  </div>

  <!-- Summary table -->
  <h3>Atalaren arabera</h3>
  <div class="zik-summary-table">
    <table>
      <thead>
        <tr>
          <th>Atala</th>
          <th style="text-align:right">Klausula<br>sakonduak</th>
          <th style="text-align:right">+ aipatuak</th>
          <th style="text-align:right">Annex A<br>sakonduak</th>
          <th style="text-align:right">+ aipatuak</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <td><a href={`/zik/${row.slug}/`} style="font-weight:600">{row.label}</a></td>
            <td class="mono" style="text-align:right">{row.covClauses.length > 0 ? `${row.covClauses.length}/${TOTAL_CLAUSES} (${row.covClausesPct}%)` : '—'}</td>
            <td class="mono muted" style="text-align:right">{row.refClauses.length > 0 ? `+${row.refClauses.length} → ${row.totalClausesPct}%` : '—'}</td>
            <td class="mono" style="text-align:right">{row.covAnnexA.length > 0 ? `${row.covAnnexA.length}/${TOTAL_ANNEX_A} (${row.covAnnexAPct}%)` : '—'}</td>
            <td class="mono muted" style="text-align:right">{row.refAnnexA.length > 0 ? `+${row.refAnnexA.length} → ${row.totalAnnexAPct}%` : '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Detail sections -->
  <h3>Xehetasuna atalez atal</h3>
  <p class="zik-legend">
    <strong>Etiketa</strong>: <span class="zik-tag zik-tag--covered">sakondua</span> atazan garatua · <span class="zik-tag zik-tag--referenced">aipatua</span> crosswalk bidezko erreferentzia
  </p>

  {rows.map((row) => {
    const totalClauses = row.covClauses.length + row.refClauses.length;
    const totalAnnexA = row.covAnnexA.length + row.refAnnexA.length;

    const clauseRows = [
      ...row.covClauses.map(id => ({id, label: clauseNames[id] || '—', tier: 'covered' as const})),
      ...row.refClauses.map(id => ({id, label: clauseNames[id] || '—', tier: 'referenced' as const})),
    ];
    const annexRows = [
      ...row.covAnnexA.map(id => ({id, label: annexANames[id] || '—', tier: 'covered' as const})),
      ...row.refAnnexA.map(id => ({id, label: annexANames[id] || '—', tier: 'referenced' as const})),
    ];

    return (
    <div class="zik-section">
      <h4><a href={`/zik/${row.slug}/`}>{row.label}</a></h4>

      {totalClauses > 0 && (
        <details class="zik-details">
          <summary>ISMS klausulak ({totalClauses})</summary>
          <table>
            <thead>
              <tr>
                <th style="width:5rem"></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {clauseRows.map((item) => (
                <tr class={`zik-row--${item.tier}`}>
                  <td class="zik-id">{item.id}</td>
                  <td>{item.label} <span class={`zik-tag zik-tag--${item.tier}`}>{item.tier === 'covered' ? 'sakondua' : 'aipatua'}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      )}

      {totalAnnexA > 0 && (
        <details class="zik-details">
          <summary>Annex A kontrolak ({totalAnnexA})</summary>
          <table>
            <thead>
              <tr>
                <th style="width:6rem"></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {annexRows.map((item) => (
                <tr class={`zik-row--${item.tier}`}>
                  <td class="zik-id">{item.id}</td>
                  <td>{item.label} <span class={`zik-tag zik-tag--${item.tier}`}>{item.tier === 'covered' ? 'sakondua' : 'aipatua'}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      )}

      {totalClauses === 0 && totalAnnexA === 0 && (
        <p class="muted" style="font-size:0.8125rem">Ez dago ISO 27001 erreferentziarik atal honetan.</p>
      )}
    </div>
    );
  })}

  <p class="zik-footnote">
    Datu hauek <code>src/data/iso27001-coverage.json</code> fitxategitik eratorriak dira,
    NIST CSF 2.0 eta ISO/IEC 27001:2022 arteko crosswalk-ean oinarrituta.
    «Sakondua» etiketak adierazten du ISO kontrola zuzenean garatzen dela atalean (ataza,
    txantiloi edo azalpen propioarekin). «Aipatua» etiketak adierazten du crosswalk
    bidez lantzen dela baina oraindik ez duela garapen espezifikorik.
    Zenbakiak orientagarriak dira; benetako ISO ziurtapenerako SoA (Statement of
    Applicability) bat beharko da, ikastetxe bakoitzaren testuingurura egokitua.
  </p>

</div>
