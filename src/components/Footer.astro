---
// src/components/Footer.astro — Custom Starlight footer
---

<div class="ft-wrapper">
  <div class="ft-row">
    <div class="ft-brand">
      <strong>Zik — Zibersegurtasuna Ikastetxeetan</strong>
      <p>Tknika — Digitaldeak</p>
    </div>
    <div class="ft-links">
      <a href="https://tknika.github.io/zibersegurtasuna-ikastetxeetan/">Jatorrizko gida</a>
      <a href="https://github.com/tknika/zik">GitHub</a>
      <a href="https://creativecommons.org/licenses/by-sa/4.0/deed.eu">CC BY-SA 4.0</a>
    </div>
  </div>
  <p class="ft-legal">
    Lege-oharra: Gida honen edukia informazio- eta sentsibilizazio-helburuetarako da eta ez da aholkularitza legala.
    Iturri ofizialak: <a href="https://www.boe.es/">BOE</a> ·
    <a href="https://eur-lex.europa.eu/">EUR-Lex</a> ·
    <a href="https://www.iso.org/standard/27001">ISO/IEC 27001</a>
  </p>
</div>

<script>
  // ── Checkbox persistence ──
  const key = 'zik-checkboxes-' + window.location.pathname;
  const saved = JSON.parse(localStorage.getItem(key) || '{}');

  const checkboxes = document.querySelectorAll('.sl-markdown-content .task-list-item input[type="checkbox"]');
  checkboxes.forEach((cb, i) => {
    cb.removeAttribute('disabled');
    if (saved[i] !== undefined) cb.checked = saved[i];
    cb.addEventListener('change', () => {
      saved[i] = cb.checked;
      localStorage.setItem(key, JSON.stringify(saved));
      updateGlobalProgress();
    });
  });

  // ── Global compliance progress in sidebar ──
  function updateGlobalProgress() {
    // Pages with their known number of checkboxes
    const pages = [
      { path: '/zik/gobernantza/',   total: 6 },
      { path: '/zik/identifikatu/',  total: 4 },
      { path: '/zik/babestu/',       total: 6 },
      { path: '/zik/detektatu/',     total: 8 },
      { path: '/zik/erantzun/',      total: 4 },
      { path: '/zik/berreskuratu/',  total: 4 },
    ];
    let grandTotal = 0, done = 0;
    pages.forEach(({ path, total }) => {
      grandTotal += total;
      const data = JSON.parse(localStorage.getItem('zik-checkboxes-' + path) || '{}');
      for (let i = 0; i < total; i++) {
        if (data[i]) done++;
      }
    });

    const fill = document.querySelector('.zik-progress-fill');
    const label = document.querySelector('.zik-progress-label');
    if (grandTotal > 0 && fill && label) {
      const pct = Math.round((done / grandTotal) * 100);
      fill.style.width = pct + '%';
      label.textContent = 'Eginbeharrak ' + pct + '% (' + done + '/' + grandTotal + ')';
    }
  }

  // Inject progress bar into sidebar content
  const sidebarContent = document.querySelector('.sidebar-content');
  if (sidebarContent && !document.getElementById('zik-progress')) {
    const el = document.createElement('div');
    el.id = 'zik-progress';
    el.className = 'zik-progress';
    el.innerHTML = `
      <div class="zik-progress-track">
        <div class="zik-progress-fill" style="width:0%"></div>
      </div>
      <span class="zik-progress-label">Eginbeharrak 0%</span>
    `;
    sidebarContent.appendChild(el);
  }

  updateGlobalProgress();
</script>

<style>
  .ft-wrapper {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    padding: 2rem 1rem;
    font-size: 0.8125rem;
    color: var(--zik-text-muted);
    line-height: 1.7;
  }

  .ft-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .ft-brand strong {
    color: var(--zik-text);
    font-size: 0.9375rem;
  }

  .ft-brand p {
    margin: 0.25rem 0 0;
  }

  .ft-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .ft-links a {
    color: var(--zik-text-secondary);
    text-decoration: none;
  }

  .ft-links a:hover {
    color: var(--zik-accent);
    text-decoration: underline;
  }

  .ft-legal {
    margin-top: 1.5rem;
    font-size: 0.75rem;
    color: var(--zik-text-muted);
  }

  .ft-legal a {
    color: var(--zik-text-muted);
    text-decoration: underline;
  }

  .ft-legal a:hover {
    color: var(--zik-accent);
  }

  :root[data-theme="dark"] .ft-brand strong {
    color: var(--zik-text-on-dark);
  }

  :root[data-theme="dark"] .ft-links a {
    color: var(--zik-text-on-dark-muted);
  }
</style>
